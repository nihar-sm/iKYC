# ============================================================
# IntelliKYC — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── AI Provider (Required for full AI functionality) ─────────────────
# Free Groq API key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model overrides (defaults are fine for most cases)
# GROQ_TEXT_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── OCR (Optional — EasyOCR runs offline with no key) ────────────────
# Free OCR.space fallback — 25 000 calls/month: https://ocr.space/ocrapi
OCR_SPACE_API_KEY=

# ── Application ──────────────────────────────────────────────────────
APP_NAME=IntelliKYC
ENVIRONMENT=development

# ── Redis (Required for session management) ──────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── File Upload ──────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# ── API ──────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
STREAMLIT_SERVER_PORT=8501

# ── Fraud Detection Thresholds ────────────────────────────────────────
FRAUD_THRESHOLD_HIGH=0.8
FRAUD_THRESHOLD_MEDIUM=0.5
FRAUD_THRESHOLD_LOW=0.3
AI_TIMEOUT_SECONDS=30
